{
  "name": "vitest-graphql-coverage",
  "version": "0.1.0",
  "description": "Istanbul-compatible coverage maps for .graphql schema files in Vitest",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/louay-hesham/vitest-graphql-coverage.git"
  },
  "license": "MIT",
  "exports": {
    "./register": {
      "import": "./dist/register.js",
      "types": "./dist/register.d.ts"
    },
    "./reporter": {
      "import": "./dist/reporter.js",
      "types": "./dist/reporter.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "graphql": "^16.0.0",
    "vitest": "^3.0.0"
  },
  "devDependencies": {
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "graphql": "^16.13.1",
    "istanbul-lib-coverage": "^3.2.2",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
